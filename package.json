{
  "name": "applai",
  "version": "1.0.0",
  "description": "Open-source AI agent for job and scholarship search, scoring, and auto-apply",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/applai.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/applai/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/applai#readme",
  "scripts": {
    "build": "tsc",
    "build:all": "tsc && cd dashboard && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:dashboard": "cd dashboard && npm run dev",
    "search": "tsx src/index.ts --run-search"
  },
  "keywords": [
    "jobs",
    "scholarships",
    "ai-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@tavily/core": "^0.5.4",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "pdf-parse": "^1.1.4",
    "playwright": "^1.50.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.13.4",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
