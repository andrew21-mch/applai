# Ollama (local LLM — run: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Tavily web search — https://tavily.com
TAVILY_API_KEY=

# Supabase — https://supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Recommended for backend API (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Email — Gmail (default) OR generic SMTP
EMAIL_USER=
EMAIL_PASS=
NOTIFICATION_EMAIL=
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=

# API security (optional — when set, POST /api/* requires x-api-secret header)
# API_SECRET=change-me
# dashboard/.env.local: NEXT_PUBLIC_API_SECRET=change-me

# Search limits
# MAX_SEARCH_QUERIES=8

# Instant alerts after search (email when new jobs score high enough)
# NOTIFY_ON_MATCH=true
# NOTIFY_MIN_SCORE=70

# Scheduler (cron — API must stay running; uses server local time unless CRON_TZ is set)
# CRON_SEARCH=0 6 * * *          # daily search (production default)
# CRON_DIGEST=0 8 * * *          # daily digest (production default)
# CRON_DIGEST=*/10 * * * *       # local dev: digest every 10 minutes
# CRON_TZ=Europe/London
# DIGEST_MIN_SCORE=60

# Server
PORT=4000
BASE_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:4001

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# Playwright — set true for headless browser during auto-apply
PLAYWRIGHT_HEADLESS=true

# Dashboard: copy to dashboard/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_API_SECRET=change-me
