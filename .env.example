# Ollama (local LLM — run: ollama serve)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Tavily web search — https://tavily.com
TAVILY_API_KEY=

# Supabase — https://supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Recommended for backend API (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications (Gmail app password)
EMAIL_USER=
EMAIL_PASS=
NOTIFICATION_EMAIL=

# Server
PORT=4000
BASE_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:4001

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1XXXXXXXXXX

# Playwright — set true for headless browser during auto-apply
PLAYWRIGHT_HEADLESS=true

# Dashboard: copy to dashboard/.env.local
# NEXT_PUBLIC_API_URL=http://localhost:4000
